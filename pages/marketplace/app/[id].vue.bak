<template>
  <div class="app-details-page">
    <!-- Loading state -->
    <div v-if="loading" class="loading-container">
      <div class="loading-spinner"></div>
      <p>Loading application details...</p>
    </div>
    
    <!-- App not found state -->
    <div v-else-if="!app" class="not-found-container">
      <div class="not-found-icon">
        <i class="fas fa-exclamation-circle"></i>
      </div>
      <h2>Application Not Found</h2>
      <p>Sorry, we couldn't find the application you're looking for.</p>
      <NuxtLink to="/marketplace" class="btn btn-primary">
        Return to Marketplace
      </NuxtLink>
    </div>

    <!-- App content -->
    <div v-else class="app-content">
      <!-- Hero Section with Enquiry Form -->
      <section class="hero-section">
        <div class="container">
          <div class="hero-content">
            <div class="hero-info">
              <div class="app-header">
                <div class="app-logo">
                  <img 
                    :src="app.logo" 
                    :alt="app.name + ' logo'" 
                    @error="handleImageError($event)" 
                    loading="lazy"
                  />
                </div>
                <div class="app-header-text">
                  <h1 class="app-name">{{ app.name }}</h1>
                  <div v-if="app.provider" class="app-provider">by {{ app.provider }}</div>
                  <div class="app-meta">
                    <div class="app-rating">
                      <div class="stars">
                        <i v-for="star in 5" :key="star" class="fas fa-star" :class="{ 'filled': star <= Math.floor(app.rating) }"></i>
                        <i v-if="app.rating % 1 >= 0.5" class="fas fa-star-half-alt filled"></i>
                      </div>
                      <span class="rating-value">{{ app.rating.toFixed(1) }}</span>
                      <span class="rating-count">({{ app.reviewCount }} reviews)</span>
                    </div>
                    <div class="app-tags">
                      <span v-for="(tag, index) in app.tags" :key="index" class="app-tag">{{ tag }}</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="hero-description">
                <p>{{ app.longDescription || app.description }}</p>
                <div class="hero-cta">
                  <button class="btn btn-primary btn-lg">Get Started</button>
                  <button class="btn btn-outline btn-lg favorite-btn" 
                    @click="toggleFavorite"
                    :class="{ 'favorited': isFavorite }"
                  >
                    <i :class="isFavorite ? 'fas fa-heart' : 'far fa-heart'"></i>
                    <span>{{ isFavorite ? 'Favorited' : 'Add to Favorites' }}</span>
                  </button>
                </div>
              </div>
            </div>
            
            <div class="enquiry-form">
              <div class="form-header">
                <h3>Request Information</h3>
                <p>Interested in {{ app.name }}? Fill out this form to get more details.</p>
              </div>
              <form @submit.prevent="submitEnquiry">
                <div class="form-group">
                  <label for="name">Full Name</label>
                  <input type="text" id="name" v-model="enquiryForm.name" required placeholder="Your name">
                </div>
                <div class="form-group">
                  <label for="email">Email</label>
                  <input type="email" id="email" v-model="enquiryForm.email" required placeholder="Your email address">
                </div>
                <div class="form-group">
                  <label for="company">Company</label>
                  <input type="text" id="company" v-model="enquiryForm.company" placeholder="Your company name">
                </div>
                <div class="form-group">
                  <label for="message">Message</label>
                  <textarea id="message" v-model="enquiryForm.message" rows="4" placeholder="What would you like to know about this application?"></textarea>
                </div>
                <button type="submit" class="btn btn-primary btn-block" :disabled="enquirySubmitting">
                  <span v-if="enquirySubmitting"><i class="fas fa-spinner fa-spin"></i> Submitting</span>
                  <span v-else>Request Info</span>
                </button>
                <p class="enquiry-policy">By submitting this form, you agree to our <a href="#">privacy policy</a>.</p>
              </form>
            </div>
          </div>
        </div>
      </section>

      <!-- About the Product Section with Media -->
      <section class="about-section" v-if="app">
        <div class="container">
          <h2 class="section-title">About {{ app.name }}</h2>
          
          <div class="about-content">
            <div class="about-text">
              <p>{{ app.longDescription || app.description }}</p>
              <p>Designed for businesses of all sizes, {{ app.name }} provides a comprehensive suite of tools that streamline operations and enhance productivity. With an intuitive user interface and powerful backend infrastructure, users can quickly implement solutions without extensive training.</p>
              <ul class="about-highlights">
                <li><i class="fas fa-check-circle"></i> Easy to implement and use</li>
                <li><i class="fas fa-check-circle"></i> Robust security features</li>
                <li><i class="fas fa-check-circle"></i> Seamless integration with other tools</li>
                <li><i class="fas fa-check-circle"></i> Regular updates and improvements</li>
                <li><i class="fas fa-check-circle"></i> Comprehensive documentation and support</li>
              </ul>
            </div>
            
            <div class="about-media">
              <div v-if="hasVideoInGallery" class="video-container">
                <iframe 
                  :src="getFirstVideo?.url" 
                  frameborder="0" 
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                  allowfullscreen
                ></iframe>
              </div>
              <div v-else-if="hasImagesInGallery" class="image-container">
                <img :src="getFirstImage?.url" :alt="getFirstImage?.caption || app.name" />
                <p v-if="getFirstImage?.caption" class="media-caption">{{ getFirstImage?.caption }}</p>
              </div>
              <div v-else class="placeholder-media">
                <i class="fas fa-desktop"></i>
                <p>Media content coming soon</p>
              </div>
            </div>
          </div>
        </div>
      </section>
      
      <!-- Application Gallery & Features with Tabs -->
      <section class="features-section" v-if="app && app.features && app.features.length > 0">
        <div class="container">
          <h2 class="section-title">Key Features</h2>
          
          <div class="tabs">
            <div class="tabs-header">
              <button 
                v-for="(tab, index) in featureTabs" 
                :key="index" 
                class="tab-button" 
                :class="{ active: activeTab === index }" 
                @click="activeTab = index"
              >
                {{ tab }}
              </button>
            </div>
            
            <div class="tabs-content">
              <!-- Features Tab -->
              <div v-if="activeTab === 0" class="tab-content">
                <div class="features-grid">
                  <div v-for="(feature, index) in app.features" :key="index" class="feature-card">
                    <div class="feature-icon">
                      <i v-if="feature.icon" :class="'fas ' + feature.icon"></i>
                      <i v-else class="fas fa-check-circle"></i>
                    </div>
                    <div class="feature-content">
                      <h3>{{ feature.title }}</h3>
                      <p>{{ feature.description }}</p>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Gallery Tab -->
              <div v-if="activeTab === 1" class="tab-content">
                <div v-if="app.gallery && app.gallery.length > 0" class="gallery-grid">
                  <div 
                    v-for="(item, index) in app.gallery" 
                    :key="index" 
                    class="gallery-item"
                    @click="openGalleryItem(index)"
                  >
                    <div v-if="item.type === 'image'" class="gallery-image">
                      <img :src="item.url" :alt="item.caption || `Gallery item ${index + 1}`" loading="lazy" />
                      <div class="gallery-caption" v-if="item.caption">{{ item.caption }}</div>
                    </div>
                    <div v-else-if="item.type === 'video'" class="gallery-video">
                      <div class="video-thumbnail">
                        <i class="fas fa-play-circle"></i>
                      </div>
                      <div class="gallery-caption" v-if="item.caption">{{ item.caption }}</div>
                    </div>
                  </div>
                </div>
                <div v-else class="no-gallery">
                  <i class="fas fa-images"></i>
                  <p>No gallery items available for this application</p>
                </div>
              </div>
              
              <!-- Use Cases Tab -->
              <div v-if="activeTab === 2" class="tab-content">
                <div class="use-cases">
                  <div class="use-case">
                    <h3>Small Businesses</h3>
                    <p>Perfect for small teams looking to streamline their operations and scale efficiently. {{ app.name }} provides affordable solutions with core functionality to help small businesses compete with larger enterprises.</p>
                    <ul>
                      <li>Easy to implement with minimal technical knowledge</li>
                      <li>Affordable pricing options</li>
                      <li>Quick onboarding process</li>
                    </ul>
                  </div>
                  <div class="use-case">
                    <h3>Enterprise Solutions</h3>
                    <p>Designed to handle the complex needs of large organizations. With advanced security features and robust scalability, {{ app.name }} can support thousands of users and manage complex workflows.</p>
                    <ul>
                      <li>Advanced security and compliance features</li>
                      <li>Custom implementation options</li>
                      <li>Enterprise-grade support and SLAs</li>
                    </ul>
                  </div>
                  <div class="use-case">
                    <h3>Industry Specific</h3>
                    <p>{{ app.name }} offers specialized solutions for various industries including healthcare, finance, education, and manufacturing. Each industry module includes tailored features to meet specific regulatory and operational needs.</p>
                    <ul>
                      <li>Industry-specific compliance features</li>
                      <li>Specialized workflows and templates</li>
                      <li>Integration with industry-standard tools</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      
      <!-- Newsletter Banner -->
      <section class="newsletter-section">
        <div class="container">
          <div class="newsletter-content">
            <div class="newsletter-text">
              <h2>Stay Up to Date</h2>
              <p class="quote">
                <i class="fas fa-quote-left"></i>
                {{ app?.name || 'This solution' }} transformed how our team collaborates and has increased our productivity by over 30%.
                <i class="fas fa-quote-right"></i>
              </p>
              <p class="quote-author">- Sarah Johnson, Marketing Director</p>
              <p class="newsletter-description">
                Subscribe to our newsletter for updates about {{ app?.name || 'this application' }}, 
                including new features, case studies, and exclusive offers.
              </p>
            </div>
            
            <div class="newsletter-form">
              <form @submit.prevent="subscribeNewsletter">
                <div class="form-group">
                  <input type="email" v-model="newsletterEmail" placeholder="Your email address" required>
                  <button type="submit" class="btn btn-primary" :disabled="newsletterSubmitting">
                    <span v-if="newsletterSubmitting"><i class="fas fa-spinner fa-spin"></i></span>
                    <span v-else>Subscribe</span>
                  </button>
                </div>
                <p class="privacy-note">
                  We respect your privacy. Unsubscribe at any time.
                </p>
              </form>
            </div>
          </div>
        </div>
      </section>
      
      <!-- Pricing Section -->
      <section class="pricing-section" v-if="app && app.pricing">
        <div class="container">
          <h2 class="section-title">Pricing Plans</h2>
          <p class="section-description">Choose the plan that fits your needs</p>
          
          <div class="pricing-tiers" v-if="app.pricing.tiers && app.pricing.tiers.length > 0">
            <div 
              v-for="(tier, index) in app.pricing.tiers" 
              :key="index" 
              class="pricing-card"
              :class="{ 'popular': tier.popular }"
            >
              <div v-if="tier.popular" class="popular-tag">Most Popular</div>
              <h3 class="tier-name">{{ tier.name }}</h3>
              <div class="tier-price">
                <span class="price">${{ tier.price }}</span>
                <span class="period">/ {{ tier.period }}</span>
              </div>
              <ul class="tier-features">
                <li v-for="(feature, featureIndex) in tier.features" :key="featureIndex">
                  <i class="fas fa-check"></i> {{ feature }}
                </li>
              </ul>
              <button class="btn btn-primary btn-block">Get Started</button>
            </div>
          </div>
          
          <div class="pricing-simple" v-else>
            <div class="pricing-card">
              <div v-if="app.pricing.type === 'free'" class="pricing-info">
                <h3 class="tier-name">Free Plan</h3>
                <div class="tier-price">
                  <span class="price">$0</span>
                  <span class="period">/ forever</span>
                </div>
                <p class="pricing-description">
                  Get started with all core features at no cost. Perfect for small teams and individuals.
                </p>
              </div>
              
              <div v-else-if="app.pricing.type === 'trial'" class="pricing-info">
                <h3 class="tier-name">Free Trial</h3>
                <div class="tier-price">
                  <span class="price">${{ app.pricing.value }}</span>
                  <span class="period">/ {{ app.pricing.period }} after trial</span>
                </div>
                <p class="pricing-description">
                  Try all features free for 14 days. No credit card required to start your trial.
                </p>
              </div>
              
              <div v-else class="pricing-info">
                <h3 class="tier-name">Standard Plan</h3>
                <div class="tier-price">
                  <span class="price">${{ app.pricing.value }}</span>
                  <span class="period">/ {{ app.pricing.period }}</span>
                </div>
                <p class="pricing-description">
                  Get access to all features with our straightforward pricing plan.
                </p>
              </div>
              
              <div class="pricing-cta">
                <button class="btn btn-primary btn-lg">
                  {{ app.pricing.type === 'free' ? 'Get Started' : app.pricing.type === 'trial' ? 'Start Free Trial' : 'Subscribe Now' }}
                </button>
                <p class="pricing-contact">Need custom pricing? <a href="#contact">Contact us</a></p>
              </div>
            </div>
          </div>
        </div>
      </section>
      
      <!-- Third-party Integrations Section -->
      <section class="integrations-section" v-if="app && app.integrations && app.integrations.length > 0">
        <div class="container">
          <h2 class="section-title">Integrations</h2>
          <p class="section-description">{{ app.name }} integrates seamlessly with your favorite tools</p>
          
          <div class="integrations-grid">
            <div 
              v-for="(integration, index) in app.integrations" 
              :key="index" 
              class="integration-item"
            >
              <div class="integration-icon">
                <img 
                  :src="`/assets/images/integrations/${integration}.svg`" 
                  :alt="`${integration} logo`" 
                  @error="handleImageError($event)" 
                  loading="lazy"
                />
              </div>
              <div class="integration-name">{{ integration.charAt(0).toUpperCase() + integration.slice(1) }}</div>
            </div>
          </div>
          
          <div class="integrations-cta">
            <button class="btn btn-outline-primary">
              <i class="fas fa-puzzle-piece"></i>
              Request Custom Integration
            </button>
          </div>
        </div>
      </section>
      
      <!-- Product Ranking and Statistics Section -->
      <section class="stats-section" v-if="app">
        <div class="container">
          <h2 class="section-title">App Statistics</h2>
          
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-icon">
                <i class="fas fa-calendar-alt"></i>
              </div>
              <div class="stat-content">
                <div class="stat-value">{{ app.launchDate ? new Date(app.launchDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) : 'N/A' }}</div>
                <div class="stat-label">Launch Date</div>
              </div>
            </div>
            
            <div class="stat-card">
              <div class="stat-icon">
                <i class="fas fa-eye"></i>
              </div>
              <div class="stat-content">
                <div class="stat-value">{{ app.monthlyViews?.toLocaleString() || 'N/A' }}</div>
                <div class="stat-label">Monthly Views</div>
              </div>
            </div>
            
            <div class="stat-card">
              <div class="stat-icon ranking-icon">
                <i class="fas fa-trophy"></i>
              </div>
              <div class="stat-content">
                <div class="stat-value">#{{ app.yearlyRank || 'N/A' }}</div>
                <div class="stat-label">Yearly Ranking</div>
              </div>
            </div>
            
            <div class="stat-card">
              <div class="stat-icon">
                <i class="fas fa-chart-line"></i>
              </div>
              <div class="stat-content">
                <div class="stat-value">#{{ app.monthlyRank || 'N/A' }}</div>
                <div class="stat-label">Monthly Ranking</div>
              </div>
            </div>
          </div>
        </div>
      </section>
      
      <!-- Social Media Sharing Section -->
      <section class="sharing-section">
        <div class="container">
          <div class="sharing-content">
            <div class="sharing-text">
              <h2>Share {{ app?.name }}</h2>
              <p>Found {{ app?.name }} useful? Share it with your network</p>
            </div>
            
            <div class="sharing-buttons">
              <!-- Twitter sharing -->
              <a :href="`https://twitter.com/intent/tweet?url=${encodeURIComponent(currentPageUrl)}&text=Check out ${app?.name} on SaaSWorld`" 
                target="_blank" rel="noopener noreferrer" class="share-button twitter">
                <i class="fab fa-twitter"></i>
                <span>Twitter</span>
              </a>
              
              <!-- LinkedIn sharing -->
              <a :href="`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(currentPageUrl)}`" 
                target="_blank" rel="noopener noreferrer" class="share-button linkedin">
                <i class="fab fa-linkedin-in"></i>
                <span>LinkedIn</span>
              </a>
              
              <!-- Facebook sharing -->
              <a :href="`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(currentPageUrl)}`" 
                target="_blank" rel="noopener noreferrer" class="share-button facebook">
                <i class="fab fa-facebook-f"></i>
                <span>Facebook</span>
              </a>
              
              <!-- Email sharing -->-->
              <a :href="`mailto:?subject=Check out ${app?.name} on SaaSWorld&body=${encodeURIComponent(`I found this great app on SaaSWorld: ${currentPageUrl}`)}`" 
                class="share-button email">
                <i class="fas fa-envelope"></i>
                <span>Email</span>
              </a>
              
              <!-- Copy link button -->
              <button @click="copyPageUrl" class="share-button copy-link">
                <i class="fas fa-link"></i>
                <span>{{ copyLinkText }}</span>
              </button>
            </div>
            
            <!-- App provider social media links -->
            <div class="provider-social-links" v-if="app?.socialLinks && app.socialLinks.length > 0">
              <div class="provider-social-text">Follow {{ app.name }} on social media:</div>
              <div class="social-icons">
                <a v-for="(social, index) in app.socialLinks" :key="index"
                  :href="social.url" target="_blank" rel="noopener noreferrer"
                  class="social-icon" :class="social.platform">
                  <i :class="`fab fa-${social.platform}`"></i>
                </a>
              </div>
            </div>
          </div>p><input type="email" id="contact-email" v-model="contactForm.email" required placeholder="Your email address"><input type="email" id="contact-email" v-model="contactForm.email" required placeholder="Your email address">
        </div>div>div>div>
      </section><div class="form-group"><div class="form-group">ion>
