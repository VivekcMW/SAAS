<script setup lang="ts">
import { ref, reactive } from 'vue';

// SEO Configuration
useSeoMeta({
  title: 'Contact Us - SaaSWorld',
  description: 'Get in touch with SaaSWorld. Have questions about our software marketplace? Need help finding the right solutions? Our team is here to help.',
  keywords: 'SaaSWorld contact, customer support, business inquiries, software help, contact form',
})

// Define the type for form data
interface ContactFormData {
  firstName: string;
  lastName: string;
  email: string;
  phone: string;
  company: string;
  subject: string;
  message: string;
  newsletter: boolean;
}

// Form data
const formData = reactive<ContactFormData>({
  firstName: '',
  lastName: '',
  email: '',
  phone: '',
  company: '',
  subject: '',
  message: '',
  newsletter: false
});

// Form state
const isSubmitting = ref(false);
const submitMessage = ref('');
const submitMessageType = ref('');

// Submit form function
const submitForm = async () => {
  isSubmitting.value = true;
  submitMessage.value = '';
  
  try {
    // Simulate API call
    await new Promise(resolve => setTimeout(resolve, 2000));
    
    // Reset form
    Object.keys(formData).forEach(key => {
      if (typeof formData[key as keyof ContactFormData] === 'boolean') {
        (formData[key as keyof ContactFormData] as boolean) = false;
      } else {
        (formData[key as keyof ContactFormData] as string) = '';
      }
    });
    
    submitMessage.value = 'Thank you for your message! We\'ll get back to you within 24 hours.';
    submitMessageType.value = 'success';
    
  } catch (error) {
    submitMessage.value = 'Sorry, there was an error sending your message. Please try again.';
    submitMessageType.value = 'error';
  } finally {
    isSubmitting.value = false;
    
    // Clear message after 5 seconds
    setTimeout(() => {
      submitMessage.value = '';
    }, 5000);
  }
};

// Schema markup for local business
useHead({
  script: [
    {
      type: 'application/ld+json',
      innerHTML: JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'SaaSWorld',
        url: 'https://saasworld.club',
        contactPoint: [
          {
            '@type': 'ContactPoint',
            contactType: 'Customer Support',
            email: 'support@saasworld.club',
            telephone: '+1-555-123-4567'
          },
          {
            '@type': 'ContactPoint',
            contactType: 'Business Inquiries',
            email: 'business@saasworld.club'
          },
          {
            '@type': 'ContactPoint',
            contactType: 'Media Inquiries',
            email: 'press@saasworld.club'
          }
        ],
        sameAs: [
          'https://twitter.com/saasworld',
          'https://linkedin.com/company/saasworld',
          'https://facebook.com/saasworld'
        ]
      })
    }
  ]
})
</script>
const setActiveLocation = (index: number) => {
  activeLocation.value = index;
};

const officeLocations = [
  {
    city: 'San Francisco',
    address: '123 Market Street, San Francisco, CA 94105',
    phone: '+1 (800) 555-1234',
    email: 'sf@saasworld.com',
    mapImage: '/assets/images/maps/san-francisco.jpg'
  },
  {
    city: 'New York',
    address: '456 Park Avenue, New York, NY 10022',
    phone: '+1 (800) 555-5678',
    email: 'nyc@saasworld.com',
    mapImage: '/assets/images/maps/new-york.jpg'
  },
  {
    city: 'London',
    address: '78 King Street, London, EC2V 8EE',
    phone: '+44 800 123 4567',
    email: 'london@saasworld.com',
    mapImage: '/assets/images/maps/london.jpg'
  }
];

// FAQs
const faqs = [
  {
    question: 'How secure is my data with SaaSWorld?',
    answer: 'At SaaSWorld, we take security very seriously. We use industry-standard encryption and security practices to protect your data. All communication is encrypted using SSL, and our infrastructure is hosted on secure cloud providers with regular security audits and compliance certifications.'
  },
  {
    question: 'Can I cancel my subscription at any time?',
    answer: 'Yes, you can cancel your subscription at any time. If you cancel, you\'ll be able to use SaaSWorld until the end of your current billing cycle. We don\'t offer refunds for partial months, but there are no cancellation fees.'
  },
  {
    question: 'Do you offer discounts for nonprofit organizations?',
    answer: 'Yes! We offer special pricing for nonprofit organizations, educational institutions, and startups. Please contact our sales team for more information on our discount programs.'
  },
  {
    question: 'How long does implementation typically take?',
    answer: 'Implementation time varies based on your specific needs and plan level. For most customers on our Starter and Professional plans, you can be up and running in a few hours. For Enterprise customers with specific integration needs, implementation might take a few days to a couple of weeks.'
  },
  {
    question: 'Can I upgrade or downgrade my plan later?',
    answer: 'Absolutely! You can upgrade your plan at any time, and the new charges will be prorated for the remainder of your current billing cycle. You can also downgrade your plan, which will take effect at the start of your next billing cycle.'
  }
];

// Form submission
const submitForm = async () => {
  try {
    isSubmitting.value = true;
    formError.value = '';
    
    // Call our API endpoint
    const response = await fetch('/api/contact', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(formData)
    });
    
    const result = await response.json();
    
    if (result.success) {
      formSubmitted.value = true;
      
      // Reset form data
      Object.keys(formData).forEach(key => {
        if (key !== 'privacyAccepted') {
          formData[key] = '';
        } else {
          formData[key] = false;
        }
      });
      
      // Scroll to form top to show success message
      setTimeout(() => {
        const formElement = document.querySelector('.contact-form-container');
        formElement?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 200);
    } else {
      formError.value = result.message || 'There was an error submitting your form. Please try again.';
    }
  } catch (error) {
    console.error('Form submission error:', error);
    formError.value = 'There was an error submitting your form. Please try again.';
  } finally {
    isSubmitting.value = false;
  }
};
</script>

