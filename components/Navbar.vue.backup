  color: #4b5563;
}

/* Responsive design */
@media (max-width: 1024px) {
  .nav-links ul {
    gap: 1.5rem;
  }

  .auth-buttons {
    gap: 0.75rem;
  }

  .btn-outline {
    padding: 0.5rem 1rem;
  }
}

@media (max-width: 768px) {
  .navbar {
    height: 64px;
  }

  .menu-toggle {
    display: block;
  }

  .nav-links {
    position: fixed;
    top: 64px;
    left: 0;
    width: 100%;
    height: calc(100vh - 64px);
    background-color: white;
    padding: 1.5rem;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    overflow-y: auto;
  }

  .nav-links.show {
    transform: translateX(0);
  }

  .nav-links ul {
    flex-direction: column;
    gap: 1rem;
  }

  .nav-links a {
    font-size: 1.1rem;
    padding: 0.75rem 0;
  }

  .nav-link-button {
    padding: 0.75rem 1.2rem !important;
    font-size: 1rem !important;
    margin: 0.5rem 0 !important;
    display: inline-block !important;
    width: auto !important;
  }

  .auth-buttons {
    display: none;
  }

  .nav-links.show ~ .auth-buttons {
    display: flex;
    flex-direction: column;
    position: fixed;
    bottom: 2rem;
    left: 1.5rem;
    right: 1.5rem;
    gap: 1rem;
  }

  .auth-buttons .btn {
    width: 100%;
    justify-content: center;
  }
  
  /* Mobile adjustments for categories drawer positioning */
  .categories-drawer-overlay {
    top: 64px; /* Match mobile navbar height */
    padding: 10px;
  }
  
  .categories-drawer {
    height: calc(100vh - 84px); /* Adjust for mobile navbar + padding */
    max-height: none;
    border-radius: 0;
  }
  
  /* Mobile adjustments for multi-select */
  .category-content-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }
  
  .category-actions {
    width: 100%;
    justify-content: space-between;
  }
  
  .apply-filters-btn,
  .category-view-all-btn {
    flex: 1;
    justify-content: center;
    max-width: 48%;
  }
  
  .subcategory-item {
