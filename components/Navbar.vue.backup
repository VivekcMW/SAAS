  background-color: rgba(37, 99, 235, 0.05);
  transform: translateY(-1px);
}

/* Login/Register button */
.auth-button {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 1.2rem;
  border-radius: 6px;
  font-weight: 500;
  font-size: 0.9rem;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
