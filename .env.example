# ─────────────────────────────────────────────────────────────────────────────
# Moonmart — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL — used for reset-password links, OG image URLs, Stripe
# success/cancel redirect URLs, and email verification links.
SITE_URL=http://localhost:3000

# Node environment. Set to "production" in deployed environments.
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file. Defaults to .data/saasworld.db
# For production, use an absolute path on a persistent volume.
# SAASWORLD_DB_PATH=/var/data/saasworld.db

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# Leave all SMTP_* vars empty to use console logging in development.
# Install nodemailer to enable real email: npm install nodemailer

# Force driver: "console" (default in dev) | "smtp" (real sends)
# MAIL_DRIVER=smtp

SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=postmaster@mg.yourdomain.com
SMTP_PASS=your-mailgun-smtp-password

# From name and address shown in email clients.
MAIL_FROM=Moonmart <no-reply@moonmart.ai>

# Admin email recipient for system notifications.
MAIL_ADMIN=admin@moonmart.ai

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use sk_test_... / pk_test_... during development.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — found in Stripe Dashboard → Webhooks → your endpoint.
# For local development run: stripe listen --forward-to localhost:3000/api/billing/webhook
# then copy the printed signing secret.
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create these in Stripe Dashboard → Products or via the API.
# Monthly prices
STRIPE_PRICE_VENDOR_GROWTH_MONTHLY=price_...
STRIPE_PRICE_BUYER_PRO_MONTHLY=price_...

# Annual prices (typically ~20% discount)
STRIPE_PRICE_VENDOR_GROWTH_ANNUAL=price_...
STRIPE_PRICE_BUYER_PRO_ANNUAL=price_...

# ── AI / OpenAI ──────────────────────────────────────────────────────────────
# Required for AI Copilot, AI Fit Check, AI Summary and AI thumbnail generation.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_org_id_here

# ── Image Generation (Stability AI) ──────────────────────────────────────────
# Required for AI thumbnail generation via Stability AI.
STABILITY_API_KEY=your_stability_api_key_here

# ── Thumbnail Settings ────────────────────────────────────────────────────────
SAVE_IMAGES_LOCALLY=true
THUMBNAIL_CACHE_DURATION=86400
DEFAULT_THUMBNAIL_STYLE=modern

# AI Generation Preferences (priority order)
AI_PROVIDER_PRIORITY=dalle,stability,canvas
ENABLE_FALLBACK_CANVAS=true

# Image Storage (optional — Cloudinary CDN for thumbnails)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Performance Settings
THUMBNAIL_GENERATION_TIMEOUT=30000
MAX_CONCURRENT_GENERATIONS=3
ENABLE_THUMBNAIL_CACHE=true

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID.
# NUXT_PUBLIC_GA_ID=G-XXXXXXXXXX
