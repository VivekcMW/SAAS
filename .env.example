# AI Thumbnail Generation Configuration

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_org_id_here

# Stability AI Configuration  
STABILITY_API_KEY=your_stability_api_key_here

# Thumbnail Settings
SAVE_IMAGES_LOCALLY=true
THUMBNAIL_CACHE_DURATION=86400
DEFAULT_THUMBNAIL_STYLE=modern

# AI Generation Preferences (priority order)
AI_PROVIDER_PRIORITY=dalle,stability,canvas
ENABLE_FALLBACK_CANVAS=true

# Image Storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Performance Settings
THUMBNAIL_GENERATION_TIMEOUT=30000
MAX_CONCURRENT_GENERATIONS=3
ENABLE_THUMBNAIL_CACHE=true
