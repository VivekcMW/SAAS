<svg width="400" height="700" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Phone Frame -->
  <rect x="20" y="20" width="360" height="660" fill="#1f2937" rx="30"/>
  <rect x="40" y="40" width="320" height="620" fill="white" rx="20"/>
  
  <!-- Status Bar -->
  <rect x="50" y="50" width="300" height="30" fill="#f8fafc"/>
  <text x="60" y="70" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">9:41 AM</text>
  <text x="300" y="70" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">100%</text>
  
  <!-- Header -->
  <rect x="50" y="90" width="300" height="60" fill="#3b82f6"/>
  <text x="70" y="125" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="white">Mobile Dashboard</text>
  
  <!-- Cards -->
  <rect x="70" y="170" width="260" height="80" fill="#e0e7ff" rx="12"/>
  <text x="90" y="195" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#3730a3">Today's Tasks</text>
  <text x="90" y="230" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#1e40af">8 / 12</text>
  
  <rect x="70" y="270" width="260" height="80" fill="#dcfce7" rx="12"/>
  <text x="90" y="295" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#166534">Messages</text>
  <text x="90" y="330" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#15803d">3 New</text>
  
  <rect x="70" y="370" width="260" height="80" fill="#fef3c7" rx="12"/>
  <text x="90" y="395" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#92400e">Notifications</text>
  <text x="90" y="430" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#d97706">5</text>
  
  <!-- Quick Actions -->
  <text x="70" y="490" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#374151">Quick Actions</text>
  
  <rect x="70" y="510" width="60" height="60" fill="#dbeafe" rx="12"/>
  <text x="85" y="545" font-family="Arial, sans-serif" font-size="24">📊</text>
  
  <rect x="140" y="510" width="60" height="60" fill="#dcfce7" rx="12"/>
  <text x="155" y="545" font-family="Arial, sans-serif" font-size="24">📝</text>
  
  <rect x="210" y="510" width="60" height="60" fill="#fef3c7" rx="12"/>
  <text x="225" y="545" font-family="Arial, sans-serif" font-size="24">👥</text>
  
  <rect x="280" y="510" width="60" height="60" fill="#fee2e2" rx="12"/>
  <text x="295" y="545" font-family="Arial, sans-serif" font-size="24">⚙️</text>
  
  <!-- Bottom Navigation -->
  <rect x="50" y="600" width="300" height="50" fill="#f3f4f6"/>
  <circle cx="90" cy="625" r="12" fill="#3b82f6"/>
  <circle cx="150" cy="625" r="12" fill="#9ca3af"/>
  <circle cx="210" cy="625" r="12" fill="#9ca3af"/>
  <circle cx="270" cy="625" r="12" fill="#9ca3af"/>
  <circle cx="330" cy="625" r="12" fill="#9ca3af"/>
</svg>
