<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4f46e5;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#7c3aed;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="url(#bg)"/>
  
  <!-- Analytics Dashboard -->
  <rect x="50" y="50" width="700" height="500" fill="white" rx="12"/>
  
  <!-- Header -->
  <rect x="70" y="70" width="660" height="60" fill="#f8fafc" rx="8"/>
  <text x="90" y="105" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#111827">Analytics & Reports</text>
  
  <!-- Charts -->
  <rect x="90" y="150" width="300" height="200" fill="#f3f4f6" rx="8"/>
  <text x="110" y="175" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#374151">Revenue Trends</text>
  
  <!-- Line chart simulation -->
  <polyline points="120,300 150,280 180,260 210,240 240,220 270,200 300,180 330,160" 
            fill="none" stroke="#3b82f6" stroke-width="3"/>
  <circle cx="120" cy="300" r="4" fill="#3b82f6"/>
  <circle cx="150" cy="280" r="4" fill="#3b82f6"/>
  <circle cx="180" cy="260" r="4" fill="#3b82f6"/>
  <circle cx="210" cy="240" r="4" fill="#3b82f6"/>
  <circle cx="240" cy="220" r="4" fill="#3b82f6"/>
  <circle cx="270" cy="200" r="4" fill="#3b82f6"/>
  <circle cx="300" cy="180" r="4" fill="#3b82f6"/>
  <circle cx="330" cy="160" r="4" fill="#3b82f6"/>
  
  <!-- Pie chart -->
  <circle cx="550" cy="250" r="80" fill="#e0e7ff"/>
  <path d="M 550 170 A 80 80 0 0 1 630 250 L 550 250 Z" fill="#3b82f6"/>
  <path d="M 630 250 A 80 80 0 0 1 550 330 L 550 250 Z" fill="#10b981"/>
  <path d="M 550 330 A 80 80 0 0 1 470 250 L 550 250 Z" fill="#f59e0b"/>
  
  <text x="450" y="175" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#374151">Market Share</text>
  
  <!-- Stats -->
  <rect x="90" y="370" width="150" height="80" fill="#dbeafe" rx="8"/>
  <text x="110" y="395" font-family="Arial, sans-serif" font-size="12" fill="#1e40af">Total Users</text>
  <text x="110" y="425" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#1e40af">125K</text>
  
  <rect x="260" y="370" width="150" height="80" fill="#dcfce7" rx="8"/>
  <text x="280" y="395" font-family="Arial, sans-serif" font-size="12" fill="#166534">Revenue</text>
  <text x="280" y="425" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#166534">$2.4M</text>
  
  <rect x="430" y="370" width="150" height="80" fill="#fed7d7" rx="8"/>
  <text x="450" y="395" font-family="Arial, sans-serif" font-size="12" fill="#991b1b">Growth</text>
  <text x="450" y="425" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#991b1b">+24%</text>
</svg>
