<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#10b981;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#059669;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="url(#bg)"/>
  
  <!-- Integration Setup UI -->
  <rect x="50" y="50" width="700" height="500" fill="white" rx="12"/>
  
  <!-- Header -->
  <rect x="70" y="70" width="660" height="60" fill="#f8fafc" rx="8"/>
  <text x="90" y="105" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#111827">Integration Setup</text>
  
  <!-- Left Panel - Available Integrations -->
  <rect x="90" y="150" width="300" height="360" fill="#f9fafb" rx="8"/>
  <text x="110" y="175" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#374151">Available Integrations</text>
  
  <!-- Integration Icons -->
  <rect x="110" y="190" width="260" height="50" fill="white" rx="8"/>
  <circle cx="135" cy="215" r="15" fill="#4285f4"/>
  <text x="160" y="220" font-family="Arial, sans-serif" font-size="14" fill="#374151">Google Workspace</text>
  <rect x="340" y="205" width="40" height="20" fill="#10b981" rx="10"/>
  <circle cx="355" cy="215" r="8" fill="white"/>
  
  <rect x="110" y="250" width="260" height="50" fill="white" rx="8"/>
  <circle cx="135" cy="275" r="15" fill="#ff6900"/>
  <text x="160" y="280" font-family="Arial, sans-serif" font-size="14" fill="#374151">HubSpot</text>
  <rect x="340" y="265" width="40" height="20" fill="#e5e7eb" rx="10"/>
  <circle cx="345" cy="275" r="8" fill="white"/>
  
  <rect x="110" y="310" width="260" height="50" fill="white" rx="8"/>
  <circle cx="135" cy="335" r="15" fill="#611f69"/>
  <text x="160" y="340" font-family="Arial, sans-serif" font-size="14" fill="#374151">Slack</text>
  <rect x="340" y="325" width="40" height="20" fill="#10b981" rx="10"/>
  <circle cx="355" cy="335" r="8" fill="white"/>
  
  <rect x="110" y="370" width="260" height="50" fill="white" rx="8"/>
  <circle cx="135" cy="395" r="15" fill="#00d4ff"/>
  <text x="160" y="400" font-family="Arial, sans-serif" font-size="14" fill="#374151">Salesforce</text>
  <rect x="340" y="385" width="40" height="20" fill="#e5e7eb" rx="10"/>
  <circle cx="345" cy="395" r="8" fill="white"/>
  
  <rect x="110" y="430" width="260" height="50" fill="white" rx="8"/>
  <circle cx="135" cy="455" r="15" fill="#ff6537"/>
  <text x="160" y="460" font-family="Arial, sans-serif" font-size="14" fill="#374151">Zapier</text>
  <rect x="340" y="445" width="40" height="20" fill="#10b981" rx="10"/>
  <circle cx="355" cy="455" r="8" fill="white"/>
  
  <!-- Right Panel - Configuration -->
  <rect x="410" y="150" width="320" height="360" fill="#f9fafb" rx="8"/>
  <text x="430" y="175" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#374151">Configuration</text>
  
  <!-- Configuration Form -->
  <rect x="430" y="190" width="280" height="40" fill="white" rx="6"/>
  <text x="445" y="205" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">API Key</text>
  <text x="445" y="220" font-family="Arial, sans-serif" font-size="14" fill="#111827">••••••••••••••••</text>
  
  <rect x="430" y="240" width="280" height="40" fill="white" rx="6"/>
  <text x="445" y="255" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Webhook URL</text>
  <text x="445" y="270" font-family="Arial, sans-serif" font-size="14" fill="#111827">https://api.example.com/webhook</text>
  
  <rect x="430" y="290" width="280" height="40" fill="white" rx="6"/>
  <text x="445" y="305" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Sync Frequency</text>
  <text x="445" y="320" font-family="Arial, sans-serif" font-size="14" fill="#111827">Every 15 minutes</text>
  
  <!-- Test Connection Button -->
  <rect x="430" y="350" width="120" height="40" fill="#3b82f6" rx="6"/>
  <text x="470" y="375" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="white">Test Connection</text>
  
  <!-- Status -->
  <circle cx="570" cy="370" r="6" fill="#10b981"/>
  <text x="585" y="375" font-family="Arial, sans-serif" font-size="12" fill="#10b981">Connected</text>
  
  <!-- Save Button -->
  <rect x="580" y="450" width="120" height="40" fill="#10b981" rx="6"/>
  <text x="625" y="475" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="white">Save Setup</text>
</svg>
